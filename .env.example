# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าให้ตรงกับเครื่องคุณ
# DATABASE_URL: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/geh_ribbon?schema=public"

# JWT secret สำหรับเซ็น token (สุ่มค่ายาว ๆ ของจริง อย่าใช้ค่านี้)
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# พอร์ตของ API server
PORT=4000

# origin ของ frontend (สำหรับ CORS + cookie)
CLIENT_ORIGIN="http://localhost:5173"

# โหมดทำงาน
NODE_ENV="development"
